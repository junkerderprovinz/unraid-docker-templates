<?xml version="1.0"?>
<Container version="2">
  <Name>ShipLog</Name>
  <Repository>ghcr.io/junkerderprovinz/shiplog:latest</Repository>
  <Registry>https://github.com/junkerderprovinz/shiplog/pkgs/container/shiplog</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/198811-support-junkerderprovinz-unraid-docker-templates/</Support>
  <Project>https://github.com/junkerderprovinz/shiplog</Project>
  <ReadMe>https://github.com/junkerderprovinz/unraid-docker-templates/blob/main/shiplog/README.md</ReadMe>
  <Overview>
    ShipLog is a read-only update advisor for your Docker host. Unraid already tells you THAT&#xD;
    an update is available and lets you apply it - ShipLog tells you WHAT actually changes and&#xD;
    HOW risky it is first: the changelog between your running image and the newest one, a&#xD;
    deterministic risk verdict (patch / minor / major), and an optional AI summary.&#xD;
    &#xD;
    It never pulls, recreates, or stops anything. The Docker socket is mounted READ-ONLY.&#xD;
    &#xD;
    Open the WebUI on port 8484. Variables with fixed options are dropdowns; the Ollama and&#xD;
    Matrix fields are optional (leave them empty to disable). The info bubble inside Unraid's&#xD;
    own Docker tab arrives via a companion plugin - see the README roadmap.
  </Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8484]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/junkerderprovinz/unraid-docker-templates/main/shiplog/shiplog.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/junkerderprovinz/unraid-docker-templates/main/shiplog/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText>If this template helps you, consider buying me a coffee.</DonateText>
  <DonateLink>https://buymeacoffee.com/junkerderprovinz</DonateLink>
  <Requires>The Docker socket, mounted READ-ONLY (/var/run/docker.sock:ro) - ShipLog only ever reads it and never issues a write call. Outbound HTTPS to image registries and GitHub is used to fetch changelogs.</Requires>

  <Config Name="WebUI Port" Target="8484" Default="8484" Mode="tcp" Description="ShipLog web interface." Type="Port" Display="always" Required="true" Mask="false">8484</Config>

  <Config Name="Docker Socket (read-only)" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="ro" Description="Mounted READ-ONLY. ShipLog lists your containers + images through it and never writes - it cannot start, stop, recreate or pull anything. Required." Type="Path" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="Config (database)" Target="/config" Default="/mnt/user/appdata/shiplog" Mode="rw" Description="Persistent SQLite database (update status + per-container history) and the optional curated changelog-mapping override." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/shiplog</Config>

  <Config Name="Poll Interval" Target="POLL_INTERVAL" Default="6h|1h|3h|12h|24h" Mode="" Description="How often ShipLog re-checks for updates - pick from the dropdown." Type="Variable" Display="always" Required="true" Mask="false">6h</Config>
  <Config Name="GitHub Token" Target="GITHUB_TOKEN" Default="" Mode="" Description="Optional. A GitHub personal access token (no scopes needed) raises the anonymous API limit used to fetch release notes - useful if you watch many GitHub-sourced images. Leave empty otherwise." Type="Variable" Display="always" Required="false" Mask="true"/>

  <Config Name="Ollama URL" Target="OLLAMA_URL" Default="" Mode="" Description="Optional. Base URL of a local Ollama instance for AI changelog summaries, e.g. http://192.168.1.10:11434 . Leave empty to disable AI summaries (everything else still works)." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Ollama Model" Target="OLLAMA_MODEL" Default="" Mode="" Description="Optional. Ollama model name for the summaries, e.g. llama3.1 . Only used when Ollama URL is set." Type="Variable" Display="always" Required="false" Mask="false"/>

  <Config Name="Matrix Homeserver" Target="MATRIX_HOMESERVER" Default="" Mode="" Description="Optional. Matrix homeserver URL for enriched push notifications when a new update is first seen, e.g. https://matrix.mydomain.tld . Leave empty to disable." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Matrix Token" Target="MATRIX_TOKEN" Default="" Mode="" Description="Optional. Matrix access token for the notifying user. Only used when Matrix Homeserver is set." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Matrix Room" Target="MATRIX_ROOM" Default="" Mode="" Description="Optional. Matrix room ID to post to, e.g. !abcdef:matrix.mydomain.tld . Only used when Matrix Homeserver is set." Type="Variable" Display="always" Required="false" Mask="false"/>

